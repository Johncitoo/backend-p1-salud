NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://admin:admin123@127.0.0.1:5433/salud_db
DATABASE_SSL=false

JWT_SECRET=dev-secret
JWT_ISSUER=salud-domiciliaria
JWT_AUDIENCE=salud-domiciliaria-api

AUTH_MODE=mock

KEYCLOAK_REALM=sistema-centralizado
KEYCLOAK_ISSUER=http://localhost/realms/sistema-centralizado
KEYCLOAK_JWKS_URI=http://localhost/realms/sistema-centralizado/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=salud-domiciliaria-api
KEYCLOAK_VALIDATE_AUDIENCE=false

# Analytics integration with Proyecto 9 (Grupo 9 - Analítica)
# ANALYTICS_ENABLED=true envía eventos reales; false solo los loguea (mock).
ANALYTICS_ENABLED=false
ANALYTICS_URL=https://analisis-proyecto-ti.onrender.com
ANALYTICS_EVENTS_PATH=/v1/events

# Notifications integration with Proyecto 6 (Grupo 6 - Notificaciones)
# NOTIFICATIONS_ENABLED=true envía solicitudes reales; false solo las loguea (mock).
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_URL=
NOTIFICATIONS_PATH=/notifications

# IoT integration with Proyecto 8 (Grupo 8 - Sensores médicos)
# IOT_ENABLED=true consulta la API real; false solo loguea (mock).
IOT_ENABLED=false
IOT_API_URL=https://iot-platform-backend-bm5b.onrender.com

# If Keycloak is exposed on port 8080, use:
# KEYCLOAK_ISSUER=http://localhost:8080/realms/sistema-centralizado
# KEYCLOAK_JWKS_URI=http://localhost:8080/realms/sistema-centralizado/protocol/openid-connect/certs
#
# If this backend runs in Docker and Keycloak is exposed on the host, keep
# KEYCLOAK_ISSUER equal to the token issuer, but use host.docker.internal for JWKS:
# KEYCLOAK_JWKS_URI=http://host.docker.internal/realms/sistema-centralizado/protocol/openid-connect/certs

FRONTEND_URL=http://localhost:5173

# R2 encrypted clinical file storage
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=proyecto1-bucket
R2_REGION=auto
FILES_ENCRYPTION_KEY=
FILES_ENCRYPTION_KEY_ID=default

# Google Calendar integration
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5173/google-calendar/callback
GOOGLE_CALENDAR_STATE_SECRET=
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY_ID=default
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=America/Santiago
GOOGLE_CALENDAR_AUTO_RETRY_ENABLED=false
GOOGLE_CALENDAR_AUTO_RETRY_INTERVAL_MS=300000
